---

### `.gitignore`

```gitignore
# Python
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebook
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# VS Code
.vscode/

# JetBrains
.idea/

# Google Colab
/content/
*.ipynb~

# Data folders
data/raw/
data/processed/
data/interim/
datasets/
*.csv
*.zip
*.tar
*.tar.gz
*.7z

# Images
*.jpg
*.jpeg
*.png
*.tif
*.tiff
*.bmp

# Model artifacts
*.pt
*.pth
*.ckpt
*.h5
*.hdf5
*.onnx
models/
checkpoints/

# Outputs
outputs/
results/
reports/
figures/
plots/

# Cache / temp
.cache/
tmp/
temp/

# Environment files
.env

# Mac
.AppleDouble
.LSOverride

